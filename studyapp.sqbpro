INSERT INTO Tests (CourseId, Title, Description, TotalQuestions, DurationMinutes, IsActive, CreatedAt)
VALUES 
(1, 'C# Fundamentals Quiz', 'Test your knowledge of C# basics including variables, data types, and control structures', 3, 30, 1, datetime('now')),
(1, 'Advanced C# Concepts', 'Challenge yourself with advanced topics like LINQ, delegates, and async programming', 3, 45, 1, datetime('now')),
(2, 'SQL Basics Assessment', 'Evaluate your understanding of SQL queries, joins, and database design', 3, 25, 1, datetime('now'));

-- Insert questions for Test 1 (C# Fundamentals Quiz)
INSERT INTO TestQuestions (TestId, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, CreatedAt)
VALUES 
(1, 'What is the correct way to declare a variable in C#?', 'var name = &quot;John&quot;;', 'string name = &quot;John&quot;;', 'name string = &quot;John&quot;;', 'declare string name = &quot;John&quot;;', 'B', datetime('now')),
(1, 'Which of the following is a value type in C#?', 'string', 'class', 'int', 'array', 'C', datetime('now')),
(1, 'What does the &quot;async&quot; keyword do?', 'Makes a method run synchronously', 'Allows a method to use await', 'Creates a new thread automatically', 'Makes a method private', 'B', datetime('now'));

-- Insert questions for Test 2 (Advanced C# Concepts)
INSERT INTO TestQuestions (TestId, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, CreatedAt)
VALUES 
(2, 'What is the purpose of LINQ?', 'To handle exceptions', 'To query data from different sources', 'To create user interfaces', 'To manage memory', 'B', datetime('now')),
(2, 'Which keyword is used to handle exceptions in C#?', 'catch', 'error', 'exception', 'throw', 'A', datetime('now')),
(2, 'What does the &quot;yield&quot; keyword do?', 'Stops method execution', 'Returns multiple values lazily', 'Creates a loop', 'Throws an exception', 'B', datetime('now'));

-- Insert questions for Test 3 (SQL Basics Assessment)
INSERT INTO TestQuestions (TestId, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, CreatedAt)
VALUES 
(3, 'Which SQL statement is used to extract data from a database?', 'GET', 'EXTRACT', 'SELECT', 'OPEN', 'C', datetime('now')),
(3, 'What does the WHERE clause do?', 'Filters records', 'Groups records', 'Sorts records', 'Joins tables', 'A', datetime('now')),
(3, 'Which JOIN returns all records from the left table?', 'INNER JOIN', 'RIGHT JOIN', 'FULL JOIN', 'LEFT JOIN', 'D', datetime('now'));</sql><current_tab id="0"/></tab_sql></sqlb_project>
